<div class="ugc-section">
  <div class="ugc-wrapper">
    {% for block in section.blocks %}
      <div class="ugc-card">
        {% if block.settings.video != blank %}
          <video 
            src="{{ block.settings.video.sources[0].url }}" 
            autoplay 
            muted 
            loop 
            playsinline
          ></video>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</div>

<style>
.ugc-section {
  padding: 20px 0;
  background: #fff;
}

.ugc-wrapper {
  display: flex;
  gap: 16px;
  overflow-x: auto;
  padding: 0 15px;
  scroll-snap-type: x mandatory;
}

.ugc-wrapper::-webkit-scrollbar {
  display: none;
}

.ugc-card {
  min-width: 180px;
  height: 320px;
  border-radius: 12px;
  overflow: hidden;
  flex-shrink: 0;
  scroll-snap-align: start;
  background: #000;
}

.ugc-card video {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
</style>

{% schema %}
{
  "name": "UGC vidéos",
  "max_blocks": 10,
  "blocks": [
    {
      "type": "video",
      "name": "Vidéo",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Vidéo UGC"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "UGC vidéos"
    }
  ]
}
{% endschema %}