<section class="ugc-section">
  <div class="ugc-container">
    {% for block in section.blocks %}
      <div class="ugc-item" {{ block.shopify_attributes }}>
        
        {% if block.settings.video != blank %}
          {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true }}
        {% elsif block.settings.image != blank %}
          <img src="{{ block.settings.image | image_url: width: 800 }}" alt="">
        {% endif %}

      </div>
    {% endfor %}
  </div>
</section>

<style>
.ugc-container {
  display: flex;
  gap: 16px;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  padding: 0 16px;
}

.ugc-item {
  flex: 0 0 80%;
  scroll-snap-align: center;
}

.ugc-item img,
.ugc-item video {
  width: 100%;
  border-radius: 12px;
}
</style>

{% schema %}
{
  "name": "UGC Premium",
  "settings": [],
  "blocks": [
    {
      "type": "media",
      "name": "Media",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "UGC Premium"
    }
  ]
}
{% endschema %}