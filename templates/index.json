    "faq": {
      "type": "faq",
      "blocks": {
        "166442457738b23caf-0": {
          "type": "item",
          "settings": {
            "title": "Is the LumaSilk safe to use at home, even if I've never done my own pedicure before?",
            "content": "<p><br/>Absolutely! LumaSilk was designed for everyday women — no professional training needed. The gentle rotating head automatically adjusts to your skin, making it impossible to over-file. Just turn it on and let it do the work. ✅<br/><br/></p>"
          }
        },
        "166442457738b23caf-1": {
          "type": "item",
          "settings": {
            "title": "How long does it take to see results?",
            "content": "<p>Most women see smoother, softer feet <strong>after just one 10-minute session</strong>. For cracked heels or stubborn calluses, 2-3 uses are enough to notice a dramatic difference — no more hiding your feet in sandal season! 👡</p>"
          }
        },
        "166442457738b23caf-2": {
          "type": "item",
          "settings": {
            "title": "Is it worth it compared to a salon pedicure?",
            "content": "<p>The average salon pedicure costs ** 45– 80** every few weeks. LumaSilk pays for itself after just <strong>one use</strong> — and you get salon-quality results from your couch, on your schedule, without the awkward small talk. 😄</p>"
          }
        },
        "item_UiHL7D": {
          "type": "item",
          "settings": {
            "title": "Will it work on severely dry or cracked heels?",
            "content": "<p>Yes — LumaSilk is specifically engineered for <strong>tough, dry skin and deep cracks</strong>, not just light maintenance. The high-speed micro-abrasion technology targets even the most stubborn calluses safely and effectively.</p>"
          }
        },
        "item_dnzf6W": {
          "type": "item",
          "settings": {
            "title": "Is it waterproof? Can I use it in the shower or bath?",
            "content": "<p><br/>LumaSilk is <strong>fully waterproof</strong> — use it dry or wet, in the shower or while relaxing in a bath. It's cordless and rechargeable, so no tangled wires, no hassle. Just grab it and go. 🚿<br/><br/></p>"
          }
        }
      },
