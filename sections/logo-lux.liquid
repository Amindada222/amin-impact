<section class="logo-marquee-luxe">
  <div class="logo-track">

    {% for block in section.blocks %}
      <div class="logo-item" {{ block.shopify_attributes }}>
        {% if block.settings.image != blank %}
          <img 
            src="{{ block.settings.image | image_url: width: 600 }}" 
            alt=""
            style="height: {{ block.settings.logo_size }}px;"
          >
        {% endif %}
      </div>
    {% endfor %}

    {% for block in section.blocks %}
      <div class="logo-item">
        {% if block.settings.image != blank %}
          <img 
            src="{{ block.settings.image | image_url: width: 600 }}" 
            alt=""
            style="height: {{ block.settings.logo_size }}px;"
          >
        {% endif %}
      </div>
    {% endfor %}

  </div>
</section>

<style>
.logo-marquee-luxe {
  position: relative;
  overflow: hidden;
  padding: 30px 0;
  background: #ffffff;
}

/* fade luxe */
.logo-marquee-luxe::before,
.logo-marquee-luxe::after {
  content: "";
  position: absolute;
  top: 0;
  width: 80px;
  height: 100%;
  z-index: 2;
}

.logo-marquee-luxe::before {
  left: 0;
  background: linear-gradient(to right, #fff, transparent);
}

.logo-marquee-luxe::after {
  right: 0;
  background: linear-gradient(to left, #fff, transparent);
}

.logo-track {
  display: flex;
  width: max-content;
  animation: marquee 25s linear infinite;
}

.logo-marquee-luxe:hover .logo-track {
  animation-play-state: paused;
}

.logo-item {
  flex: 0 0 auto;
  margin: 0 50px;
  display: flex;
  align-items: center;
}

/* logos */
.logo-item img {
  width: auto;
  opacity: 0.6;
  filter: grayscale(100%);
  transition: all 0.3s ease;
}

.logo-item img:hover {
  opacity: 1;
  filter: grayscale(0%);
  transform: scale(1.05);
}

@keyframes marquee {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

/* mobile */
@media screen and (max-width: 768px) {
  .logo-item {
    margin: 0 25px;
  }
}
</style>

{% schema %}
{
  "name": "Logo défilant luxe",
  "settings": [],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image du logo"
        },
        {
          "type": "range",
          "id": "logo_size",
          "label": "Taille du logo",
          "min": 20,
          "max": 120,
          "step": 2,
          "default": 40
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Logo défilant luxe"
    }
  ]
}
{% endschema %}