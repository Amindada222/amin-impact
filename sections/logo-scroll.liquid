<div class="logo-scroll">
  <div class="logo-track">

    {% for block in section.blocks %}
      <div class="logo-item">
        {% if block.settings.image != blank %}
          <img src="{{ block.settings.image | image_url }}" alt="">
        {% endif %}
        
        {% if block.settings.text != blank %}
          <p>{{ block.settings.text }}</p>
        {% endif %}
      </div>
    {% endfor %}

    {% for block in section.blocks %}
      <div class="logo-item">
        {% if block.settings.image != blank %}
          <img src="{{ block.settings.image | image_url }}" alt="">
        {% endif %}
        
        {% if block.settings.text != blank %}
          <p>{{ block.settings.text }}</p>
        {% endif %}
      </div>
    {% endfor %}

  </div>
</div>

<style>
.logo-scroll {
  overflow: hidden;
  background: #fff;
  padding: 15px 0;
}

.logo-track {
  display: flex;
  width: max-content;
  animation: scroll 20s linear infinite;
}

.logo-item {
  display: flex;
  align-items: center;
  gap: 8px;
  margin: 0 30px;
  white-space: nowrap;
}

.logo-item img {
  width: 30px;
}

.logo-item p {
  font-size: 14px;
  color: #333;
}

@keyframes scroll {
  from {
    transform: translateX(0);
  }
  to {
    transform: translateX(-50%);
  }
}
</style>

{% schema %}
{
  "name": "Logo défilant",
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image du logo"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Texte"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Logo défilant"
    }
  ]
}
{% endschema %}