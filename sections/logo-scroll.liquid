<div class="logo-scroll">
  <div class="logo-track">
    {% for block in section.blocks %}
      <div class="logo-item">
        {% if block.settings.image %}
          <img 
            src="{{ block.settings.image | image_url: width: block.settings.logo_size }}"
            style="height: {{ block.settings.logo_size }}px;"
          >
        {% endif %}
        {% if block.settings.text != blank %}
          <span>{{ block.settings.text }}</span>
        {% endif %}
      </div>
    {% endfor %}

    {% for block in section.blocks %}
      <div class="logo-item">
        {% if block.settings.image %}
          <img 
            src="{{ block.settings.image | image_url: width: block.settings.logo_size }}"
            style="height: {{ block.settings.logo_size }}px;"
          >
        {% endif %}
        {% if block.settings.text != blank %}
          <span>{{ block.settings.text }}</span>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</div>

<style>
.logo-scroll {
  overflow: hidden;
  background: #fff;
  padding: 10px 0;
}

.logo-track {
  display: flex;
  width: max-content;
  animation: scroll 18s linear infinite;
}

.logo-item {
  display: flex;
  align-items: center;
  gap: 8px;
  margin: 0 30px;
  white-space: nowrap;
}

.logo-item img {
  display: block;
}

.logo-item span {
  font-size: 14px;
  color: #222;
}

@keyframes scroll {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}
</style>

{% schema %}
{
  "name": "Logo défilant",
  "max_blocks": 20,
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image du logo"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Texte",
          "default": "Votre texte"
        },
        {
          "type": "range",
          "id": "logo_size",
          "label": "Taille du logo",
          "min": 20,
          "max": 120,
          "step": 2,
          "default": 40
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Logo défilant"
    }
  ]
}
{% endschema %}