<section class="ugc-video-section">
  <div class="ugc-video-container">
    
    {% for block in section.blocks %}
      <div class="ugc-video-card" {{ block.shopify_attributes }}>
        
        {% if block.settings.video != blank %}
          <video 
            autoplay 
            muted 
            loop 
            playsinline
          >
            <source src="{{ block.settings.video.sources[0].url }}" type="video/mp4">
          </video>
        {% endif %}

      </div>
    {% endfor %}

  </div>
</section>

<style>
.ugc-video-section {
  padding: 60px 20px;
  background: #f5f5f5;
}

/* ✅ CENTRAGE + SCROLL */
.ugc-video-container {
  display: flex;
  gap: 20px;
  overflow-x: auto;
  justify-content: center;
  scroll-snap-type: x mandatory;
}

/* ✅ CARD FORMAT FIXE */
.ugc-video-card {
  flex: 0 0 auto;
  width: 220px;
  aspect-ratio: 9 / 16; /* 🔥 FORCE FORMAT IDENTIQUE */
  border-radius: 16px;
  overflow: hidden;
  scroll-snap-align: center;
  background: #000;
}

/* ✅ VIDEO S'ADAPTE AU FORMAT */
.ugc-video-card video {
  width: 100%;
  height: 100%;
  object-fit: cover; /* 🔥 coupe pour remplir */
  display: block;
}

/* ✅ MOBILE */
@media screen and (max-width: 768px) {
  .ugc-video-container {
    justify-content: flex-start;
    padding-left: 10px;
  }
}
</style>

{% schema %}
{
  "name": "UGC Videos",
  "settings": [],
  "blocks": [
    {
      "type": "video",
      "name": "Vidéo",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Choisir une vidéo"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "UGC Videos"
    }
  ]
}
{% endschema %}