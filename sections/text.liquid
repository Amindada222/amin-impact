<div class="premium-text-section">
  <div class="premium-wrapper">

    {% if section.settings.rating_text != blank %}
      <div class="rating fade-up">
        <span class="stars">★★★★★</span>
        <span class="rating-text">{{ section.settings.rating_text }}</span>
      </div>
    {% endif %}

    {% if section.settings.badge != blank %}
      <div class="badge fade-up">
        {{ section.settings.badge }}
      </div>
    {% endif %}

    {% if section.settings.title != blank %}
      <h2 class="title fade-up">
        <span class="counter" data-target="{{ section.settings.number }}">
          {{ section.settings.number }}
        </span>+
        {{ section.settings.title }}
      </h2>
    {% endif %}

    {% if section.settings.subtitle != blank %}
      <p class="subtitle fade-up">
        {{ section.settings.subtitle }}
      </p>
    {% endif %}

  </div>
</div>

<style>
.premium-text-section {
  padding: 80px 20px;
  text-align: center;
  background: #f9f9f9;
}

.premium-wrapper {
  max-width: 900px;
  margin: 0 auto;
}

/* rating */
.rating {
  font-size: 14px;
  margin-bottom: 18px;
  color: #333;
  letter-spacing: 0.3px;
}

.stars {
  color: #00b67a;
  margin-right: 6px;
  letter-spacing: 3px;
  font-size: 16px;
}

.rating-text {
  font-weight: 500;
}

/* badge */
.badge {
  display: inline-block;
  background: #eeeeee;
  padding: 8px 16px;
  border-radius: 25px;
  font-size: 12px;
  margin-bottom: 25px;
  font-weight: 600;
  letter-spacing: 0.5px;
}

/* title */
.title {
  font-size: 36px;
  font-weight: 700;
  margin-bottom: 18px;
  color: #111;
  line-height: 1.3;
}

.counter {
  font-weight: 800;
}

/* subtitle */
.subtitle {
  font-size: 17px;
  color: #666;
  max-width: 600px;
  margin: 0 auto;
}

/* animation */
.fade-up {
  opacity: 0;
  transform: translateY(30px);
  transition: all 0.8s ease;
}

.fade-up.visible {
  opacity: 1;
  transform: translateY(0);
}
</style>

<script>
document.addEventListener("DOMContentLoaded", function () {

  // animation apparition
  const elements = document.querySelectorAll(".fade-up");

  const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add("visible");
      }
    });
  }, { threshold: 0.2 });

  elements.forEach(el => observer.observe(el));


  // compteur animé
  const counter = document.querySelector(".counter");

  if (counter) {
    let started = false;

    const runCounter = () => {
      if (started) return;
      started = true;

      const target = +counter.getAttribute("data-target");
      let count = 0;

      const speed = target / 80;

      const update = () => {
        count += speed;
        if (count < target) {
          counter.innerText = Math.floor(count).toLocaleString();
          requestAnimationFrame(update);
        } else {
          counter.innerText = target.toLocaleString();
        }
      };

      update();
    };

    const counterObserver = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          runCounter();
        }
      });
    }, { threshold: 0.5 });

    counterObserver.observe(counter);
  }

});
</script>

{% schema %}
{
  "name": "Texte premium +",
  "settings": [
    {
      "type": "text",
      "id": "rating_text",
      "label": "Texte note",
      "default": "4,8/5 RATING FROM VERIFIED CUSTOMERS"
    },
    {
      "type": "text",
      "id": "badge",
      "label": "Badge",
      "default": "VERIFIED CUSTOMER REVIEWS"
    },
    {
      "type": "number",
      "id": "number",
      "label": "Nombre",
      "default": 25000
    },
    {
      "type": "text",
      "id": "title",
      "label": "Suite du titre",
      "default": "Happy customers across the USA"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "Discover why thousands trust your brand."
    }
  ],
  "presets": [
    {
      "name": "Texte premium +"
    }
  ]
}
{% endschema %}