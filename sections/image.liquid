<div class="ugc-images-section">
  <div class="ugc-container">
    {% for block in section.blocks %}
      <div class="ugc-image-card">
        
        {% if block.settings.image != blank %}
          <img src="{{ block.settings.image | image_url: width: 600 }}" alt="">
        {% endif %}

      </div>
    {% endfor %}
  </div>
</div>

<style>
.ugc-images-section {
  padding: 60px 20px;
  background: #f5f5f5;
}

.ugc-container {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 25px;
  max-width: 1100px;
  margin: 0 auto;
}

.ugc-image-card {
  border-radius: 16px;
  overflow: hidden;
}

.ugc-image-card img {
  width: 100%;
  height: auto;
  display: block;
  border-radius: 16px;
}

/* ✅ mobile */
@media screen and (max-width: 768px) {
  .ugc-container {
    grid-template-columns: 1fr;
  }
}
</style>

{% schema %}
{
  "name": "UGC Images (packaging)",
  "settings": [],
  "blocks": [
    {
      "type": "image",
      "name": "Image client",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "UGC Images"
    }
  ]
}
{% endschema %}