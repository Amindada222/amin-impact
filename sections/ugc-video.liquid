<div class="ugc-section">
  <div class="ugc-wrapper">
    {% for block in section.blocks %}
      <div class="ugc-card" style="width: {{ block.settings.width }}px;">
        
        {% if block.settings.video != blank %}
          <video 
            src="{{ block.settings.video.sources[0].url }}"
            autoplay
            muted
            loop
            playsinline
          ></video>
        {% endif %}

      </div>
    {% endfor %}
  </div>
</div>

<style>
.ugc-section {
  padding: 60px 0;
  background: #fff;
  overflow: hidden;
}

/* ✅ WRAPPER CENTRÉ */
.ugc-wrapper {
  display: flex;
  gap: 20px;
  overflow-x: auto;
  scroll-snap-type: x mandatory;

  /* CENTRAGE DESKTOP */
  padding-left: calc((100vw - 1000px) / 2);
  padding-right: calc((100vw - 1000px) / 2);
}

/* ✅ MOBILE FIX */
@media screen and (max-width: 1000px) {
  .ugc-wrapper {
    padding-left: 20px;
    padding-right: 20px;
  }
}

/* ✅ CARD */
.ugc-card {
  flex: 0 0 auto;
  border-radius: 12px;
  overflow: hidden;
  scroll-snap-align: start;
}

/* ✅ VIDEO */
.ugc-card video {
  width: 100%;
  height: auto;
  display: block;
  border-radius: 12px;
}
</style>

{% schema %}
{
  "name": "UGC Vidéos",
  "settings": [],
  "blocks": [
    {
      "type": "video",
      "name": "Vidéo",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Vidéo"
        },
        {
          "type": "range",
          "id": "width",
          "label": "Largeur vidéo (px)",
          "min": 120,
          "max": 400,
          "step": 10,
          "default": 220
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "UGC Vidéos"
    }
  ]
}
{% endschema %}